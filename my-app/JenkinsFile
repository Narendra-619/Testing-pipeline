pipeline {
    agent any

    stages {

        stage("Install") {
            steps {
                dir('my-app') {
                    sh 'npm install'
                }
            }
        }

        stage("Build") {
            steps {
                dir('my-app') {
                    sh 'npm run build'
                }
            }
        }

        stage("Archive") {
            steps {
                archiveArtifacts artifacts: 'my-app/dist/**', fingerprint: true
            }
        }
    }

    post {
        success {
            echo "Build completed successfully."
        }

        failure {
            echo "Build failed. Please check the console logs."
        }

        always {
            echo "Pipeline execution finished."
        }
    }
}